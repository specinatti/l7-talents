# Banco de dados (Railway fornece automaticamente)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT - gere uma chave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_jwt_super_secreta_aqui

# Ambiente
NODE_ENV=production
PORT=3000

# Frontend URL (para CORS em produção)
FRONTEND_URL=https://seu-dominio.railway.app
